pipeline {
    agent any

    environment {
        NODE_ENV = 'test'
    }

    stages {

        stage('Clean') {
            steps {
                deleteDir()
            }
        }

        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/anuradha2430/campus-food-system.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install'
            }
        }

        stage('Test') {
            steps {
                bat 'set NODE_ENV=test&& npm test'
            }
        }

        stage('Build Docker') {
            steps {
                bat 'docker build -t campus-food .'
            }
        }

        stage('Run') {
            steps {
                bat '''
                docker stop campus-food-container || exit 0
                docker rm campus-food-container || exit 0
                docker run -d -p 3000:3000 --name campus-food-container campus-food
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline Success!'
        }
        failure {
            echo '❌ Pipeline Failed!'
        }
    }
}