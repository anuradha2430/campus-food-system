pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/anuradha2430/campus-food-system.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install'
            }
        }

        stage('Test') {
            steps {
                bat 'npm test || echo No tests'
            }
        }

        stage('Build Docker') {
            steps {
                bat 'docker build -t campus-food .'
            }
        }

        stage('Run') {
            steps {
                bat 'docker run -d -p 3000:3000 campus-food'
            }
        }
    }
}