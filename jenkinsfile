pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/anuradha2430/To-DoList.git'
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                sh 'npm test'
            }
        }

        stage('Build Docker') {
            steps {
                sh 'docker build -t campus-food-app .'
            }
        }

        stage('Run') {
            steps {
                sh 'docker run -d -p 3000:3000 campus-food-app'
            }
        }
    }
}